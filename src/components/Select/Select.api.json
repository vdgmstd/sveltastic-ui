[
	{
		"name": "value",
		"type": "V | V[]",
		"required": false,
		"default": "$bindable()",
		"description": "Bound selection. Scalar in single mode, array in `multiple`."
	},
	{
		"name": "items",
		"type": "SelectItems<V>",
		"required": false,
		"default": "[]",
		"description": "Items to render. Mix flat items and grouped sections freely."
	},
	{
		"name": "multiple",
		"type": "boolean",
		"required": false,
		"default": "false",
		"description": "Multiple selection."
	},
	{
		"name": "filter",
		"type": "boolean",
		"required": false,
		"default": "false",
		"description": "Inline text filter."
	},
	{
		"name": "disabled",
		"type": "boolean",
		"required": false,
		"default": "false",
		"description": "Disabled."
	},
	{
		"name": "loading",
		"type": "boolean",
		"required": false,
		"default": "false",
		"description": "Spinner indicator (visual only)."
	},
	{
		"name": "fieldState",
		"type": "InputState",
		"required": false,
		"default": "'default'",
		"description": "State color tint (matches Input)."
	},
	{
		"name": "variant",
		"type": "InputVariant",
		"required": false,
		"default": "'default'",
		"description": "Visual style. Mirrors Input."
	},
	{
		"name": "block",
		"type": "boolean",
		"required": false,
		"default": "false",
		"description": "Stretch to container width."
	},
	{
		"name": "collapseChips",
		"type": "boolean",
		"required": false,
		"default": "false",
		"description": "Collapse multi-chips after the first to a \"+N\" pill."
	},
	{
		"name": "openAnim",
		"type": "SelectOpenAnim",
		"required": false,
		"default": "'pop'",
		"description": "Dropdown panel open/close animation."
	},
	{
		"name": "labelStyle",
		"type": "InputLabelStyle",
		"required": false,
		"default": "'default'",
		"description": "Label / placeholder behaviour."
	},
	{
		"name": "label",
		"type": "string",
		"required": false,
		"default": null,
		"description": "Static label."
	},
	{
		"name": "placeholder",
		"type": "string",
		"required": false,
		"default": "''",
		"description": "Placeholder text."
	},
	{
		"name": "color",
		"type": "Color",
		"required": false,
		"default": "'primary'",
		"description": "Palette color."
	},
	{
		"name": "notData",
		"type": "Snippet",
		"required": false,
		"default": null,
		"description": "Empty-state content (overrides default tray + \"No data\")."
	},
	{
		"name": "caret",
		"type": "Snippet<[boolean]>",
		"required": false,
		"default": null,
		"description": "Custom indicator icon (replaces the default chevron). Receives `isOpen`."
	},
	{
		"name": "option",
		"type": "Snippet<[SelectItem<V>, boolean]>",
		"required": false,
		"default": null,
		"description": "Custom row renderer. Receives the item and whether it's selected."
	},
	{
		"name": "groupTitle",
		"type": "Snippet<[string]>",
		"required": false,
		"default": null,
		"description": "Custom group-title renderer. Receives the section title."
	},
	{
		"name": "selected",
		"type": "Snippet<[SelectItem<V>]>",
		"required": false,
		"default": null,
		"description": "Custom renderer for the selected value inside the trigger field (single mode only)."
	},
	{
		"name": "chip",
		"type": "Snippet<[SelectItem<V>, () => void]>",
		"required": false,
		"default": null,
		"description": "Custom renderer for chips in `multiple` mode."
	},
	{
		"name": "field",
		"type": "Snippet<[SelectFieldContext<V>]>",
		"required": false,
		"default": null,
		"description": "Full trigger-field override. When provided, replaces the entire `<Input>`-based field — consumer renders whatever markup they want. Receives the selection / filter / chip context."
	},
	{
		"name": "message",
		"type": "Snippet",
		"required": false,
		"default": null,
		"description": "Feedback message under the field."
	},
	{
		"name": "onchange",
		"type": "(value: V | V[] | undefined) => void",
		"required": false,
		"default": null,
		"description": "Fires when the selection changes."
	}
]