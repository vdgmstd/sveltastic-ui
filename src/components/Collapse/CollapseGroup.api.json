	},
	{
		"name": "header",
		"type": "Snippet",
		"required": false,
		"default": null,
		"description": "Header snippet — overrides `title`."
	},
	{
		"name": "footer",
		"type": "Snippet",
		"required": false,
		"default": null,
		"description": "Footer row below the items."
