{
	"name": "sveltastic-ui",
	"version": "1.1.8",
	"description": "Svelte 5 + Tailwind v4 component library — runes-native, SSR-safe, tree-shakable.",
	"type": "module",
	"license": "MIT",
	"keywords": [
		"svelte",
		"svelte5",
		"sveltekit",
		"ui",
		"components",
		"tailwind",
		"tailwindcss",
		"runes"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vdgmstd/sveltastic-ui.git"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles": {
			"types": "./dist/styles.d.ts",
			"default": "./dist/styles/tokens.css"
		}
	},
	"scripts": {
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"package": "svelte-package --input src --output dist",
		"prepublishOnly": "npm run package"
	},
	"peerDependencies": {
		"svelte": "^5",
		"tailwindcss": "^4"
	},
	"dependencies": {
		"@js-temporal/polyfill": "^0.5.1",
		"clsx": "^2.1.1",
		"maska": "^3.2.0",
		"phosphor-svelte": "^3",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.0",
		"phosphor-svelte": "^3.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3"
	}
}
